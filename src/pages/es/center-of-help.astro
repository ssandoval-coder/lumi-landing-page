---
import Layout from '../../layouts/Layout.astro';
import LanguageSelector from '../../components/LanguageSelector.astro';
import Footer from '../../components/Home/Footer.astro';
import { getTranslations } from '../../i18n';
import "../../styles/global.css";

const currentLang = 'es';
const t = getTranslations(currentLang);
const currentPath = Astro.url.pathname;
---

<Layout lang={currentLang} title={`${t.centerOfHelp.title} - Lumi`}>
	<main class="min-h-screen flex flex-col justify-start items-center p-6 sm:p-10">
		<div class="w-full max-w-4xl bg-white rounded-[28px] shadow-[0_20px_60px_rgba(15,30,60,0.1)] px-6 sm:px-12 py-10 flex flex-col gap-8">
			<div class="flex justify-between items-start">
				<p class="text-xs sm:text-sm uppercase tracking-[0.3em] text-[#8c8f98]">{t.centerOfHelp.support}</p>
				<LanguageSelector currentLang={currentLang} currentPath={currentPath} />
			</div>
			<div>
				<h1 class="text-3xl font-semibold text-[#1c1c1e]">{t.centerOfHelp.title}</h1>
				<p class="text-base text-[#5b5f69] leading-relaxed mt-2">{t.centerOfHelp.description}</p>
			</div>

			<div class="flex flex-col gap-10">
				{t.centerOfHelp.categories.map((category) => (
					<section class="flex flex-col gap-3">
						<h2 class="text-lg font-semibold text-[#1c1c1e] border-b border-[#eef0f5] pb-2">{category.title}</h2>
						<div class="flex flex-col gap-2">
							{category.faqs.map((faq) => (
								<details class="group rounded-2xl border border-[#eef0f5] bg-[#fafbff] overflow-hidden">
									<summary class="flex justify-between items-center px-5 py-4 cursor-pointer list-none text-[#1c1c1e] font-medium text-sm sm:text-base select-none">
										<span>{faq.q}</span>
										<span class="ml-4 text-[#8c8f98] transition-transform duration-200 group-open:rotate-45 flex-shrink-0 text-xl leading-none">+</span>
									</summary>
									<div class="px-5 pb-4 pt-1 text-sm sm:text-base text-[#5b5f69] leading-relaxed border-t border-[#eef0f5]">
										{faq.a}
									</div>
								</details>
							))}
						</div>
					</section>
				))}
			</div>

			<p class="text-sm text-center text-[#8c8f98] pt-4 border-t border-[#eef0f5]">
				{t.centerOfHelp.contactPrompt}
			</p>
		</div>
	</main>
	<Footer lang={currentLang} />
</Layout>
