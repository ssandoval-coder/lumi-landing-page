---
import Layout from '../../layouts/Layout.astro';
---

<Layout lang="es" title="Conectar Lumi con ChatGPT">
  <main class="oauth-shell">
    <section class="oauth-card" aria-labelledby="oauth-title">
      <div class="brand">
        <img src="/favicon.svg" alt="" />
        <span>Lumi</span>
      </div>
      <h1 id="oauth-title">Conectar Lumi con ChatGPT</h1>
      <p class="intro">
        Accede con tu cuenta Lumi para usar orientación personalizada con los
        perfiles que decidas compartir.
      </p>
      <p id="status" class="status" role="status">Preparando autorización…</p>

      <form id="login-form" class="stack" hidden>
        <div class="provider-list" aria-label="Opciones de inicio de sesión">
          <button id="google-login" class="provider-button" type="button">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M21.6 12.23c0-.71-.06-1.4-.18-2.07H12v3.92h5.38a4.6 4.6 0 0 1-2 3.02v2.54h3.24c1.9-1.75 2.98-4.33 2.98-7.41Z" />
              <path fill="#34A853" d="M12 22c2.7 0 4.98-.9 6.63-2.43l-3.24-2.53c-.9.6-2.05.96-3.39.96-2.61 0-4.82-1.76-5.61-4.13H3.05v2.62A10 10 0 0 0 12 22Z" />
              <path fill="#FBBC05" d="M6.39 13.87A6 6 0 0 1 6.08 12c0-.65.11-1.28.31-1.87V7.51H3.05A10 10 0 0 0 2 12c0 1.61.38 3.14 1.05 4.49l3.34-2.62Z" />
              <path fill="#EA4335" d="M12 6c1.47 0 2.79.5 3.83 1.5l2.87-2.87A9.63 9.63 0 0 0 12 2a10 10 0 0 0-8.95 5.51l3.34 2.62C7.18 7.76 9.39 6 12 6Z" />
            </svg>
            Continuar con Google
          </button>
          <button id="apple-login" class="provider-button" type="button">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M17.05 12.54c-.03-3 2.45-4.46 2.56-4.53a5.5 5.5 0 0 0-4.33-2.34c-1.82-.19-3.59 1.09-4.52 1.09-.94 0-2.37-1.07-3.9-1.04a5.76 5.76 0 0 0-4.84 2.96c-2.1 3.64-.53 8.98 1.48 11.92 1 1.44 2.17 3.04 3.7 2.98 1.5-.06 2.06-.96 3.87-.96 1.79 0 2.32.96 3.88.93 1.61-.03 2.63-1.44 3.59-2.89a11.9 11.9 0 0 0 1.64-3.35 5.17 5.17 0 0 1-3.13-4.77ZM14.09 3.74A5.25 5.25 0 0 0 15.29 0a5.37 5.37 0 0 0-3.47 1.78 5 5 0 0 0-1.23 3.6 4.44 4.44 0 0 0 3.5-1.64Z" />
            </svg>
            Continuar con Apple
          </button>
        </div>

        <div class="divider"><span>o continúa con tu correo</span></div>

        <label>
          Correo electrónico
          <input id="email" name="email" type="email" autocomplete="email" required />
        </label>
        <label>
          Contraseña
          <input id="password" name="password" type="password" autocomplete="current-password" required />
        </label>
        <button id="email-login" class="primary-button" type="submit">Iniciar sesión</button>
      </form>

      <div id="consent" class="stack" hidden>
        <p><strong id="client-name">ChatGPT</strong> solicita acceso de solo lectura.</p>
        <div class="permission">
          <strong>Permisos solicitados</strong>
          <ul id="scope-list"></ul>
        </div>
        <p class="privacy-note">
          ChatGPT no recibirá contraseñas, identificadores internos ni el perfil completo
          de tus bebés. Puedes revocar el acceso posteriormente.
        </p>
        <div class="actions">
          <button id="deny" class="secondary-button" type="button">Cancelar</button>
          <button id="approve" class="primary-button" type="button">Permitir acceso</button>
        </div>
      </div>

      <p id="error" class="error" role="alert" hidden></p>
      <a class="privacy-link" href="/es/polices/privacy-policy">Política de privacidad</a>
    </section>
  </main>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const authorizationId = new URLSearchParams(window.location.search).get('authorization_id');

    const status = document.querySelector('#status');
    const errorBox = document.querySelector('#error');
    const loginForm = document.querySelector('#login-form');
    const consent = document.querySelector('#consent');
    const clientName = document.querySelector('#client-name');
    const scopeList = document.querySelector('#scope-list');
    const googleButton = document.querySelector('#google-login');
    const appleButton = document.querySelector('#apple-login');
    const emailButton = document.querySelector('#email-login');
    const approveButton = document.querySelector('#approve');
    const denyButton = document.querySelector('#deny');
    const loginButtons = [googleButton, appleButton, emailButton];

    const showError = (message) => {
      errorBox.textContent = message;
      errorBox.hidden = false;
      status.textContent = '';
    };

    const setLoginBusy = (busy) => {
      for (const button of loginButtons) {
        button.disabled = busy;
      }
    };

    if (!supabaseUrl || !supabaseAnonKey) {
      showError('La autenticación de Lumi no está configurada en este entorno.');
    } else if (!authorizationId) {
      showError('Esta pantalla se abre al conectar Lumi desde ChatGPT. Inicia la conexión desde ChatGPT para continuar.');
    } else {
      const supabase = createClient(supabaseUrl, supabaseAnonKey, {
        auth: {
          persistSession: true,
          autoRefreshToken: true,
          detectSessionInUrl: true,
        },
      });

      const redirect = (data) => {
        if (!data?.redirect_url) throw new Error('OAuth redirect missing');
        window.location.assign(data.redirect_url);
      };

      const loadAuthorization = async () => {
        errorBox.hidden = true;
        status.textContent = 'Verificando tu cuenta Lumi…';
        const { data: sessionData } = await supabase.auth.getSession();
        if (!sessionData.session) {
          status.textContent = '';
          loginForm.hidden = false;
          consent.hidden = true;
          return;
        }

        loginForm.hidden = true;
        const { data, error } = await supabase.auth.oauth.getAuthorizationDetails(authorizationId);
        if (error || !data) {
          showError('No fue posible verificar la solicitud. Intenta conectar Lumi nuevamente desde ChatGPT.');
          return;
        }
        if ('redirect_url' in data) {
          redirect(data);
          return;
        }

        clientName.textContent = data.client?.name || 'ChatGPT';
        scopeList.replaceChildren();
        const labels = {
          openid: 'Confirmar tu identidad Lumi',
          profile: 'Consultar información básica de tu cuenta',
          email: 'Consultar el correo asociado a tu cuenta',
        };
        for (const scope of data.scope.split(' ').filter(Boolean)) {
          const item = document.createElement('li');
          item.textContent = labels[scope] || scope;
          scopeList.appendChild(item);
        }
        status.textContent = '';
        consent.hidden = false;
      };

      const signInWithProvider = async (provider) => {
        errorBox.hidden = true;
        setLoginBusy(true);
        status.textContent = provider === 'google'
          ? 'Conectando con Google…'
          : 'Conectando con Apple…';

        const redirectTo = new URL(window.location.href);
        redirectTo.hash = '';
        const { error } = await supabase.auth.signInWithOAuth({
          provider,
          options: {
            redirectTo: redirectTo.toString(),
          },
        });

        if (error) {
          setLoginBusy(false);
          showError('No pudimos iniciar sesión con ese proveedor. Intenta nuevamente.');
        }
      };

      googleButton.addEventListener('click', () => signInWithProvider('google'));
      appleButton.addEventListener('click', () => signInWithProvider('apple'));

      loginForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        errorBox.hidden = true;
        setLoginBusy(true);
        status.textContent = 'Iniciando sesión…';
        const form = new FormData(loginForm);
        const { error } = await supabase.auth.signInWithPassword({
          email: String(form.get('email') || ''),
          password: String(form.get('password') || ''),
        });
        if (error) {
          setLoginBusy(false);
          showError('No pudimos iniciar sesión. Revisa tus credenciales.');
          return;
        }
        await loadAuthorization();
      });

      approveButton.addEventListener('click', async () => {
        approveButton.disabled = true;
        denyButton.disabled = true;
        status.textContent = 'Conectando Lumi…';
        const { data, error } = await supabase.auth.oauth.approveAuthorization(
          authorizationId,
          { skipBrowserRedirect: true },
        );
        if (error || !data) {
          approveButton.disabled = false;
          denyButton.disabled = false;
          showError('No fue posible completar la autorización.');
          return;
        }
        redirect(data);
      });

      denyButton.addEventListener('click', async () => {
        approveButton.disabled = true;
        denyButton.disabled = true;
        status.textContent = 'Cancelando…';
        const { data, error } = await supabase.auth.oauth.denyAuthorization(
          authorizationId,
          { skipBrowserRedirect: true },
        );
        if (error || !data) {
          approveButton.disabled = false;
          denyButton.disabled = false;
          showError('No fue posible cancelar la autorización.');
          return;
        }
        redirect(data);
      });

      loadAuthorization().catch(() => {
        showError('No fue posible preparar la autorización.');
      });
    }
  </script>
</Layout>

<style>
  :global(body) {
    background:
      radial-gradient(circle at 12% 12%, rgb(217 98 94 / 18%), transparent 30%),
      radial-gradient(circle at 88% 88%, rgb(123 165 242 / 22%), transparent 32%),
      #f4f0e8;
    color: #17233d;
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  }

  .oauth-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 24px;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  .oauth-card {
    width: min(100%, 480px);
    box-sizing: border-box;
    background: rgb(255 255 255 / 94%);
    border: 1px solid rgb(217 98 94 / 18%);
    border-radius: 28px;
    padding: clamp(24px, 5vw, 38px);
    box-shadow: 0 24px 70px rgb(23 35 61 / 16%);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #d9625e;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .brand img {
    width: 34px;
    height: 34px;
  }

  h1 {
    margin: 22px 0 10px;
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    line-height: 1.1;
    letter-spacing: -0.035em;
  }

  .intro {
    margin: 0;
    color: #4a5a72;
    line-height: 1.55;
  }

  .status,
  .privacy-note {
    color: #4a5a72;
  }

  .status {
    min-height: 1.5em;
    margin: 16px 0 0;
  }

  .stack {
    display: grid;
    gap: 15px;
    margin-top: 18px;
  }

  .provider-list {
    display: grid;
    gap: 10px;
  }

  label {
    display: grid;
    gap: 7px;
    font-weight: 650;
  }

  input {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid #d7dce5;
    border-radius: 14px;
    padding: 13px 14px;
    background: white;
    color: inherit;
    font: inherit;
    outline: none;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }

  input:focus {
    border-color: #d9625e;
    box-shadow: 0 0 0 4px rgb(217 98 94 / 13%);
  }

  button {
    border: 0;
    min-height: 48px;
    border-radius: 14px;
    padding: 12px 18px;
    font: inherit;
    font-weight: 750;
    cursor: pointer;
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  button:not(:disabled):hover {
    transform: translateY(-1px);
  }

  .provider-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    border: 1px solid #d7dce5;
    background: white;
    color: #17233d;
  }

  .provider-button:hover {
    border-color: #b9c2d0;
    box-shadow: 0 8px 20px rgb(23 35 61 / 8%);
  }

  .provider-button svg {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
  }

  .primary-button {
    background: #d9625e;
    color: white;
    box-shadow: 0 8px 18px rgb(217 98 94 / 22%);
  }

  .primary-button:hover {
    background: #c95350;
    box-shadow: 0 12px 24px rgb(217 98 94 / 28%);
  }

  button:disabled {
    cursor: wait;
    opacity: 0.55;
  }

  .secondary-button {
    border: 1px solid #d7dce5;
    background: #f6f7fa;
    color: #17233d;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #6a778c;
    font-size: 0.82rem;
    text-align: center;
  }

  .divider::before,
  .divider::after {
    content: '';
    height: 1px;
    flex: 1;
    background: #e2e5eb;
  }

  .permission {
    padding: 16px;
    border-radius: 16px;
    background: #f7f1ef;
    border: 1px solid rgb(217 98 94 / 12%);
  }

  .permission ul {
    margin: 10px 0 0;
    padding-left: 20px;
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }

  .error {
    color: #8f2f2c;
    background: #fff0ef;
    border: 1px solid rgb(217 98 94 / 22%);
    border-radius: 14px;
    padding: 13px 14px;
  }

  .privacy-link {
    display: inline-block;
    margin-top: 24px;
    color: #b74744;
    font-weight: 650;
    text-underline-offset: 3px;
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 520px) {
    .oauth-shell {
      padding: 14px;
    }

    .oauth-card {
      border-radius: 22px;
    }

    .actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
