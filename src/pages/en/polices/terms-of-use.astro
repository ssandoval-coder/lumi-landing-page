---
import Layout from '../../../layouts/Layout.astro';
import LanguageSelector from '../../../components/LanguageSelector.astro';
import Footer from '../../../components/Home/Footer.astro';
import { getTranslations } from '../../../i18n';
import "../../../styles/global.css";

const currentLang = 'en';
const t = getTranslations(currentLang);
const currentPath = Astro.url.pathname;

const sections = [
	t.termsOfUse.aboutUs,
	t.termsOfUse.registration,
	t.termsOfUse.serviceDescription,
	t.termsOfUse.subscriptions,
	t.termsOfUse.aiDisclaimer,
	t.termsOfUse.userObligations,
	t.termsOfUse.intellectualProperty,
	t.termsOfUse.feedback,
	t.termsOfUse.termination,
	t.termsOfUse.liability,
	t.termsOfUse.modifications,
	t.termsOfUse.contact,
];
---

<Layout lang={currentLang} title={`${t.termsOfUse.title} - Lumi`}>
	<main class="min-h-screen flex flex-col justify-start items-center p-6 sm:p-10">
		<div class="w-full max-w-4xl bg-white rounded-[28px] shadow-[0_20px_60px_rgba(15,30,60,0.1)] px-6 sm:px-12 py-10 flex flex-col gap-6">
			<div class="flex justify-between items-start">
				<p class="text-xs sm:text-sm uppercase tracking-[0.3em] text-[#8c8f98]">{t.common.polices}</p>
				<LanguageSelector currentLang={currentLang} currentPath={currentPath} />
			</div>
			<div>
				<h1 class="text-3xl font-semibold text-[#1c1c1e]">{t.termsOfUse.title}</h1>
				<p class="text-xs text-[#8c8f98] mt-1">{t.termsOfUse.lastUpdated}</p>
			</div>
			<p class="text-base text-[#5b5f69] leading-relaxed">
				{t.termsOfUse.description}
			</p>

			<section class="flex flex-col gap-8 mt-4">
				{sections.map((section) => (
					<article class="space-y-3">
						<h2 class="text-2xl font-semibold text-[#1c1c1e]">{section.title}</h2>
						<div class="space-y-4">
							{section.content.split('\n\n').map((paragraph: string) => (
								<p class="text-base text-[#5b5f69] leading-relaxed">{paragraph}</p>
							))}
						</div>
					</article>
				))}
			</section>
		</div>
	</main>
	<Footer lang={currentLang} />
</Layout>
