---
import { getTranslations, type Language } from '../../i18n';

interface Props {
	lang?: Language;
}

const { lang = 'es' } = Astro.props;
const t = getTranslations(lang);
---

<section class="hero-section w-full pt-28 pb-16">
	<div class="mx-auto grid w-full max-w-5xl grid-cols-1 items-center gap-12 px-6 md:grid-cols-2">
		<div class="space-y-7">
			<div class="inline-flex items-center gap-2 rounded-full border border-[#D9625E]/20 bg-white/80 px-4 py-1.5 text-sm font-medium text-[#D9625E]">
				<span class="relative flex h-2 w-2">
					<span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#D9625E] opacity-60"></span>
					<span class="relative inline-flex h-2 w-2 rounded-full bg-[#D9625E]"></span>
				</span>
				Disponible en App Store y Play Store
			</div>

			<h1 class="hero-title text-5xl font-bold leading-[1.05] tracking-tight text-[#17233d] md:text-6xl lg:text-7xl">
				{t.home.hero.titleLine1}
				<span class="block text-[#d9625e]">{t.home.hero.titleLine2}</span>
			</h1>

			<p class="max-w-xl text-lg leading-relaxed text-[#4a5a72] md:text-xl">
				{t.home.hero.subtitle}
			</p>

			<div class="flex flex-wrap items-center gap-4">
				<a
					href="https://www.apple.com/cl/app-store/"
					class="store-btn-primary inline-flex h-14 w-44 items-center gap-3 rounded-2xl bg-[#17233d] px-6 text-base font-semibold text-white transition-all duration-300 ease-out hover:-translate-y-1 active:translate-y-0"
				>
					<svg width="16" height="20" viewBox="0 0 16 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
						<path d="M10.48 3.14C11.13 2.35 11.59 1.23 11.5 0.14C10.53 0.19 9.38 0.78 8.69 1.57C8.07 2.26 7.51 3.39 7.63 4.46C8.72 4.54 9.83 3.93 10.48 3.14Z" fill="white"/>
						<path d="M15.1 14.1C14.68 15.05 14.48 15.48 13.95 16.3C13.2 17.47 12.14 18.93 10.82 18.94C9.65 18.95 9.35 18.2 7.76 18.21C6.18 18.22 5.85 18.96 4.68 18.95C3.36 18.94 2.36 17.62 1.61 16.45C-0.49 13.16 -0.71 9.31 0.58 7.33C1.5 5.92 2.95 5.09 4.31 5.09C5.69 5.09 6.56 5.85 7.74 5.85C8.88 5.85 9.58 5.09 11.16 5.09C12.37 5.09 13.66 5.75 14.57 6.89C11.58 8.52 12.06 12.79 15.1 14.1Z" fill="white"/>
					</svg>
					<div class="text-left">
						<div class="text-[10px] font-normal opacity-70 leading-none">Descarga en</div>
						<div class="text-sm font-bold leading-tight">App Store</div>
					</div>
				</a>

				<a
					href="https://play.google.com/store/games?hl=es_419&pli=1"
					class="store-btn-secondary inline-flex h-14 w-44 items-center gap-3 rounded-2xl border border-[#d5d8df] bg-white px-6 text-base font-semibold text-[#17233d] transition-all duration-300 ease-out hover:-translate-y-1 active:translate-y-0"
				>
					<svg width="18" height="20" viewBox="0 0 18 20" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M1.21 0.55L10.75 10L1.2 19.45C0.86 19.12 0.66 18.62 0.66 18.04V1.96C0.66 1.38 0.86 0.88 1.21 0.55Z" fill="#1D1D1D" />
						<path d="M13.76 13.01L4.3 18.4L11.05 11.7L13.76 13.01Z" fill="#1D1D1D" />
						<path d="M13.76 6.99L11.05 8.3L4.29 1.6L13.76 6.99Z" fill="#1D1D1D" />
						<path d="M17.34 10C17.34 10.57 17.03 11.09 16.53 11.36L14.63 12.45L11.35 10L14.63 7.55L16.53 8.64C17.03 8.91 17.34 9.43 17.34 10Z" fill="#1D1D1D" />
					</svg>
					<div class="text-left">
						<div class="text-[10px] font-normal opacity-50 leading-none">Descarga en</div>
						<div class="text-sm font-bold leading-tight">Play Store</div>
					</div>
				</a>
			</div>
		</div>

		<div class="flex justify-center md:justify-end">
			<div class="phone-float relative w-[308px] rounded-[2.2rem] bg-[#1d2b45] p-2.5 phone-glow">
				<div class="h-[624px] w-[288px] overflow-hidden rounded-[1.8rem] bg-[#faf8f2]">
					<img
						src="/image 16.png"
						alt="Lumi Star"
						class="h-full w-full object-cover object-center"
					/>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero-section {
		background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(217, 98, 94, 0.08) 0%, transparent 70%),
		            linear-gradient(180deg, #f4f0e8 0%, #faf8f4 60%, #ffffff 100%);
	}

	.hero-title {
		font-family: 'Lora', Georgia, serif;
	}

	.phone-glow {
		box-shadow:
			0 0 0 1px rgba(217, 98, 94, 0.12),
			0 24px 60px rgba(20, 30, 50, 0.22),
			0 0 80px rgba(217, 98, 94, 0.12);
	}

	.phone-float {
		animation: phoneFloat 3.5s ease-in-out infinite;
		will-change: transform;
	}

	@keyframes phoneFloat {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(10px); }
	}

	.store-btn-primary {
		box-shadow: 0 8px 24px rgba(23, 35, 61, 0.22);
	}
	.store-btn-primary:hover {
		box-shadow: 0 14px 32px rgba(23, 35, 61, 0.32);
	}

	.store-btn-secondary {
		box-shadow: 0 4px 14px rgba(23, 35, 61, 0.07);
	}
	.store-btn-secondary:hover {
		border-color: #bcc5d3;
		box-shadow: 0 10px 24px rgba(23, 35, 61, 0.13);
	}
</style>
