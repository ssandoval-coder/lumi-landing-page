---
import { getTranslations, type Language } from '../../i18n';

interface Props {
	lang?: Language;
}

const { lang = 'es' } = Astro.props;
const t = getTranslations(lang);
---

<div class="mx-auto grid w-full max-w-4xl place-items-center gap-5 px-4 md:grid-cols-2 md:place-items-stretch md:gap-8 md:px-0">

	<!-- Plan Basic -->
	<div class="plan-card-basic w-full max-w-[330px] rounded-3xl border border-slate-100 bg-white p-8 md:max-w-none md:p-10">
		<h3 class="plan-title mb-1 text-xl font-bold text-[#17233d] md:text-2xl">{t.home.plans.basicName}</h3>
		<p class="mb-6 text-sm text-slate-400 md:text-base">{t.home.plans.basicDescription}</p>
		<div class="mb-7 md:mb-8">
			<span class="text-4xl font-extrabold text-[#17233d] md:text-5xl">{t.home.plans.basicPrice}</span>
		</div>
		<ul class="mb-8 space-y-3 text-sm md:mb-10 md:space-y-4 md:text-base">
			<li class="flex items-center gap-3 text-slate-600">
				<span class="check-icon flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-slate-100">
					<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#64748b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</span>
				{t.home.plans.basicFeature1}
			</li>
			<li class="flex items-center gap-3 text-slate-600">
				<span class="check-icon flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-slate-100">
					<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#64748b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</span>
				{t.home.plans.basicFeature2}
			</li>
			<li class="flex items-center gap-3 text-slate-600">
				<span class="check-icon flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-slate-100">
					<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#64748b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</span>
				{t.home.plans.basicFeature3}
			</li>
		</ul>
		<a
			href="https://www.apple.com/cl/app-store/"
			class="block w-full rounded-xl border-2 border-[#17233d]/10 bg-white py-3 text-center text-sm font-semibold text-[#17233d] transition-all duration-200 hover:border-[#17233d]/30 hover:bg-slate-50 md:text-base"
		>
			Empezar gratis
		</a>
	</div>

	<!-- Plan Max -->
	<div class="plan-card-max relative w-full max-w-[330px] overflow-hidden rounded-3xl bg-[#18202E] p-8 text-white md:max-w-none md:scale-105 md:p-10">
		<!-- Badge -->
		<div class="absolute right-6 top-6 rounded-full bg-[#D9625E] px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">
			Más popular
		</div>

		<!-- Decorative glow -->
		<div class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-[#D9625E]/10 blur-3xl"></div>

		<h3 class="plan-title mb-1 text-xl font-bold md:text-2xl">{t.home.plans.maxName}</h3>
		<p class="mb-6 text-sm text-slate-400 md:text-base">{t.home.plans.maxDescription}</p>
		<div class="mb-7 md:mb-8">
			<span class="text-4xl font-extrabold md:text-5xl">$7.99</span>
			<span class="text-base font-normal text-slate-400 md:text-lg">{t.home.plans.maxPriceUnit}</span>
		</div>
		<ul class="mb-8 space-y-3 text-sm md:mb-10 md:space-y-4 md:text-base">
			<li class="flex items-center gap-3 text-slate-200">
				<span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#D9625E]/20">
					<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#D9625E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</span>
				{t.home.plans.maxFeature1}
			</li>
			<li class="flex items-center gap-3 text-slate-200">
				<span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#D9625E]/20">
					<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#D9625E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</span>
				{t.home.plans.maxFeature2}
			</li>
			<li class="flex items-center gap-3 text-slate-200">
				<span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#D9625E]/20">
					<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#D9625E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</span>
				{t.home.plans.maxFeature3}
			</li>
			<li class="flex items-center gap-3 text-slate-200">
				<span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#D9625E]/20">
					<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#D9625E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</span>
				{t.home.plans.maxFeature4}
			</li>
		</ul>
		<a
			href="https://www.apple.com/cl/app-store/"
			class="block w-full rounded-xl bg-[#D9625E] py-3 text-center text-sm font-bold text-white transition-all duration-200 hover:bg-[#c8514d] md:text-base"
			style="box-shadow: 0 4px 20px rgba(217, 98, 94, 0.35);"
		>
			Probar Lumi Max
		</a>
	</div>
</div>

<style>
	.plan-title {
		font-family: 'Lora', Georgia, serif;
	}
	.plan-card-basic {
		box-shadow: 0 1px 4px rgba(23, 35, 61, 0.05), 0 4px 20px rgba(23, 35, 61, 0.06);
	}
	.plan-card-max {
		box-shadow: 0 8px 40px rgba(23, 35, 61, 0.25), 0 0 60px rgba(217, 98, 94, 0.08);
	}
</style>
